{
  "model_config": {
    "mathir": {
      "name": "MATHIR",
      "description": "Memory-Augmented Transformer with Hierarchical Retention",
      "architecture": {
        "vision_encoder": {
          "input_channels": 1,
          "input_height": 84,
          "input_width": 84,
          "conv_channels": [32, 64, 128],
          "output_dim": 256
        },
        "state_dim": 9,
        "action_dim": 2,
        "memory": {
          "working": {
            "capacity": 64,
            "attention_heads": 4,
            "description": "Court terme - fenêtre glissante"
          },
          "episodic": {
            "capacity": 1000,
            "mem_slots": 512,
            "compressed_dim": 64,
            "description": "Moyen terme - buffer circulaire d'épisodes",
            "use_adaptive_rerank": true,
            "adaptive_dense_threshold": 0.9,
            "use_cross_encoder": true,
            "cross_encoder_model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
            "dense_top_k": 20,
            "bm25_top_k": 20,
            "cross_encoder_top_n": 30,
            "rrf_k_const": 60,
            "bm25_weight": 1.0
          },
          "semantic": {
            "prototypes": 256,
            "dim": 64,
            "update_rate": 0.01,
            "description": "Long terme - prototypes k-means"
          }
        },
        "retention": {
          "decay_rates": [0.9, 0.7, 0.5],
          "description": "3 échelles temporelles (rapide/moyen/lent)"
        },
        "actor": {
          "hidden_dims": [128, 64],
          "output_dim": 2,
          "activation": "GELU"
        }
      },
      "expected_performance": {
        "retention_1000_steps": 0.85,
        "generalization_avg": 0.858,
        "vram_batch_32_gb": 4.1,
        "inference_time_ms": 10
      }
    },
    "lstm": {
      "name": "LSTM Baseline",
      "description": "Architecture LSTM traditionnelle",
      "architecture": {
        "vision_encoder": {
          "input_channels": 1,
          "input_height": 84,
          "input_width": 84,
          "conv_channels": [32, 64, 128],
          "output_dim": 256
        },
        "state_dim": 9,
        "action_dim": 2,
        "lstm": {
          "num_layers": 2,
          "hidden_dim": 256,
          "dropout": 0.1,
          "description": "2 couches LSTM avec dropout"
        },
        "actor": {
          "hidden_dims": [128, 64],
          "output_dim": 2,
          "activation": "GELU"
        }
      },
      "expected_performance": {
        "retention_1000_steps": 0.15,
        "generalization_avg": 0.616,
        "vram_batch_32_gb": 3.2,
        "inference_time_ms": 7
      }
    }
  },
