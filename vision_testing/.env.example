# MATHIR Playground — Environment Variables
# Copy to .env (gitignored) and fill in your values.

# OpenRouter API key (https://openrouter.ai/keys)
# Can also be set via OPENROUTER_API_KEY env var.
OPENROUTER_API_KEY=

# OpenRouter API base (default: https://openrouter.ai/api/v1)
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Request timeout in seconds (default: 120)
OPENROUTER_TIMEOUT_SECONDS=120

# Max retries on 429 rate-limit (default: 2)
OPENROUTER_MAX_RETRIES=2

# Default model when none selected (must exist in config.json:models)
OPENROUTER_DEFAULT_MODEL=openrouter/free

# OpenCode Zen API key (https://opencode.ai/auth)
# Get yours at https://opencode.ai/auth, then add to .env or OPENCODE_ZEN_API_KEY env var.
OPENCODE_ZEN_API_KEY=

# OpenCode Zen API base (default: https://opencode.ai/zen/v1)
OPENCODE_ZEN_API_BASE=https://opencode.ai/zen/v1

# MATHIR daemon (optional, enables /api/memory/* routes in ui_server.py)
MATHIR_DAEMON_HOST=127.0.0.1
MATHIR_DAEMON_PORT=7338

# UI server (Flask)
UI_HOST=127.0.0.1
UI_PORT=5000
UI_DEBUG=false

# Camera defaults
CAMERA_DEVICE_ID=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# Audio defaults
AUDIO_PUSH_TO_TALK_KEY=Space
AUDIO_MAX_RECORD_SECONDS=30

# Theme: dark | light | auto
UI_THEME=auto