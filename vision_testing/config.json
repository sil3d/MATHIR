  "_add_model_help": {
    "how_to_add": "Edit this config to add any GGUF vision/audio model. Example:",
    "example_model": {
      "MyCustomModel": {
        "enabled": true,
        "type": "vision-language",
        "display_name": "My Custom Model",
        "path": "models/MyModel/model.gguf",
        "mmproj": "models/MyModel/mmproj.gguf",
        "size_mb": 1000,
        "vram_mb": 2000,
        "supports_vision": true
      }
    },
    "available_types": ["vision-language", "audio", "text-only"],
