{
  "_comment": "User-editable config for vision_testing. All paths are RELATIVE to this config file (or absolute if needed). Edit this file to add/remove models and change settings. NO hardcoded paths in code.",

  "bin_dir": "bin",
  "models_dir": "models",
  "memory": {
    "backend": "daemon",
    "daemon_port": 7338,
    "mem_type": "episodic",
    "label": "vision_test"
  },

  "llama_server": {
    "_comment": "Default llama-server settings - can be overridden per model",
    "executable": "llama-server.exe",
    "linux_executable": "llama-server",
    "macos_executable": "llama-server",
    "default_port": 8080,
    "default_ctx_size": 4096,
    "default_n_gpu_layers": 20,
    "auto_start_browser": false,
    "log_level": "info"
  },

  "models": {
    "LFM2.5-VL-1.6B-Q4_0": {
      "_comment": "LiquidAI vision-language model - sees and describes images",
      "enabled": true,
      "type": "vision-language",
      "display_name": "LFM2.5 Vision 1.6B (Q4_0)",
      "description": "LiquidAI vision-language model, 1.6B params, 8GB VRAM friendly",
      "path": "models/LFM2.5-VL-1.6B-GGUF/LFM2.5-VL-1.6B-Q4_0.gguf",
      "mmproj": "models/LFM2.5-VL-1.6B-GGUF/mmproj-LFM2.5-VL-1.6b-Q8_0.gguf",
      "size_mb": 1220,
      "vram_mb": 2400,
      "context_length": 4096,
      "supports_vision": true,
      "supports_audio": false,
      "huggingface_url": "https://huggingface.co/LiquidAI/LFM2.5-VL-1.6B-GGUF"
    },
    "LFM2.5-Audio-1.5B-Q4_0": {
