# MATHIR benchmark .env example
# Copy this to .env and fill in your values.
# .env is gitignored — your keys stay local.

# =============================================================================
# LLM provider
# =============================================================================
# Options: api | openrouter | ollama | auto
# - "openrouter" requires MATHIR_API_KEY (and uses openrouter.ai/api/v1)
# - "ollama"   uses local Ollama (http://127.0.0.1:11434)
# - "auto"     picks based on whether MATHIR_API_KEY is set
MATHIR_LLM_BACKEND=openrouter

# =============================================================================
# API key (NEVER commit — only in your local .env)
# =============================================================================
# Get a free key at: https://openrouter.ai/keys
MATHIR_API_KEY=sk-or-v1-PUT-YOUR-KEY-HERE-DONT-COMMIT

# =============================================================================
# Model
# =============================================================================
# OpenRouter free models curated for the benchmark (see python llm_client.py list-free):
#   meta-llama/llama-3.3-70b-instruct:free     (70B, recommended)
#   qwen/qwen3-next-80b-a3b-instruct:free      (80B, long context)
#   openai/gpt-oss-120b:free                   (120B GPT-class)
#   google/gemma-4-31b-it:free                 (31B)
#   meta-llama/llama-3.2-3b-instruct:free      (3B, fast)
#   nvidia/nemotron-3-nano-30b-a3b:free        (30B)
MATHIR_API_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Custom API base (only if not using OpenRouter default)
# MATHIR_API_BASE=https://api.minimax.chat/v1

# OpenRouter ranking headers (optional, helps get on free-tier rate limits)
# MATHIR_OPENROUTER_REFERER=https://github.com/sil3d/MATHIR
# MATHIR_OPENROUTER_TITLE=MATHIR Benchmark

# =============================================================================
# Ollama (only used if MATHIR_LLM_BACKEND=ollama)
# =============================================================================
MATHIR_OLLAMA_URL=http://127.0.0.1:11434
MATHIR_OLLAMA_MODEL=qwen3.5:2b
