# MATHIR Benchmarks — Centralized environment file
# Copy to .env (same dir) and fill in your values. .env is gitignored.
#
# Usage from any benchmark subdirectory:
#   - python auto-loads via _env.py helper if you `from _env import *`
#   - OR source manually before running: `set -a && . .env && set +a`
#   - OR export individually: `MATHIR_API_KEY=sk-... python benchmarks/04_.../ai_cognitive_bench.py`

# =============================================================================
# LLM provider backend
# =============================================================================
# - "openrouter" : cloud, free models at https://openrouter.ai/keys
# - "ollama"     : local Ollama at http://localhost:11434
# - "api"        : direct OpenAI-compatible API (set MATHIR_API_BASE)
# - "auto"       : picks based on whether MATHIR_API_KEY is set
MATHIR_LLM_BACKEND=auto

# =============================================================================
# API keys (NEVER commit)
# =============================================================================
# OpenRouter (free tier available)
# Get one at: https://openrouter.ai/keys
MATHIR_API_KEY=
OPENROUTER_API_KEY=

# Cross-LLM benchmark providers (used by 01_cross_llm_benchmark)
GOOGLE_AI_STUDIO_KEY=
MINIMAX_API_KEY=
NVIDIA_API_KEY=
OPENCODE_ZEN_KEY=

# =============================================================================
# API base + model
# =============================================================================
# Custom API base (only if not using OpenRouter)
# MATHIR_API_BASE=https://api.openrouter.ai/api/v1

# Model for OpenRouter (free models curated for benchmarks)
# Options: meta-llama/llama-3.3-70b-instruct:free (recommended)
#          qwen/qwen3-next-80b-a3b-instruct:free
#          openai/gpt-oss-120b:free
#          google/gemma-4-31b-it:free
#          meta-llama/llama-3.2-3b-instruct:free (fast)
MATHIR_API_MODEL=meta-llama/llama-3.3-70b-instruct:free

# =============================================================================
# Ollama (only if MATHIR_LLM_BACKEND=ollama)
# =============================================================================
MATHIR_OLLAMA_URL=http://localhost:11434
MATHIR_OLLAMA_MODEL=qwen3.5:2b

# =============================================================================
# Cross-LLM benchmark — models per provider
# =============================================================================
# 01_cross_llm_benchmark/benchmark.py uses these models:
GOOGLE_MODEL=gemini-2.5-pro
MINIMAX_MODEL=MiniMax-Text-01
NVIDIA_MODEL=meta/llama-4-maverick-17b-128e-instruct
OPENCODE_ZEN_MODEL=opencode/zen-mini

# =============================================================================
# OpenRouter ranking (optional, helps free-tier rate limits)
# =============================================================================
MATHIR_OPENROUTER_REFERER=https://github.com/sil3d/MATHIR
MATHIR_OPENROUTER_TITLE=MATHIR Benchmark
